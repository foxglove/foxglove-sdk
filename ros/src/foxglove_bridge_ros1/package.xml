<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>foxglove_bridge_ros1</name>
  <version>3.4.1</version>
  <description>
    ROS 1 frontend for the Foxglove bridge: connects ROS 1 topics, services,
    and parameters to Foxglove clients over a local WebSocket server and,
    when enabled, the Foxglove remote access gateway. Built on
    foxglove_bridge_core.
  </description>
  <maintainer email="ros-tooling@foxglove.dev">Foxglove</maintainer>
  <license>MIT</license>
  <url type="website">https://github.com/foxglove/foxglove-sdk</url>

  <!-- This package is ROS 1 only. The conditions keep rosdep happy when it
       scans the source tree in a ROS 2 environment (a COLCON_IGNORE file
       excludes it from colcon builds there). -->
  <buildtool_depend condition="$ROS_VERSION == 1">catkin</buildtool_depend>

  <!-- ROS-agnostic bridge core (transports, SDK ownership) -->
  <depend condition="$ROS_VERSION == 1">foxglove_bridge_core</depend>

  <depend condition="$ROS_VERSION == 1">resource_retriever</depend>
  <depend condition="$ROS_VERSION == 1">roscpp</depend>
  <depend condition="$ROS_VERSION == 1">rosgraph_msgs</depend>
  <depend condition="$ROS_VERSION == 1">topic_tools</depend>
  <depend condition="$ROS_VERSION == 1">ros_babel_fish</depend>

  <export>
    <build_type>catkin</build_type>
  </export>
</package>

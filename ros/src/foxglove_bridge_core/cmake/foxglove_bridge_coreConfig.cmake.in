# CMake package config for foxglove_bridge_core.
#
# Hand-written (configured at build time, not generated by install(EXPORT))
# because the exported targets depend on prebuilt SDK libraries imported from
# the FetchContent'd dist — the same reason the SDK dist ships a hand-written
# config. Defines:
#
#   foxglove_bridge_core::foxglove_cpp          - SDK C++ wrapper (+ headers, + RA define)
#   foxglove_bridge_core::foxglove_bridge_core  - the core library
#
# and sets FOXGLOVE_BRIDGE_CORE_REMOTE_ACCESS to ON/OFF to reflect how the
# package was built.

if(TARGET foxglove_bridge_core::foxglove_bridge_core)
  return()
endif()

set(FOXGLOVE_BRIDGE_CORE_REMOTE_ACCESS @FOXGLOVE_BRIDGE_REMOTE_ACCESS@)

# share/foxglove_bridge_core/cmake -> install prefix
get_filename_component(_fbc_prefix "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)

add_library(foxglove_bridge_core::foxglove_cpp SHARED IMPORTED)
set_target_properties(foxglove_bridge_core::foxglove_cpp PROPERTIES
  IMPORTED_LOCATION "${_fbc_prefix}/lib/${CMAKE_SHARED_LIBRARY_PREFIX}foxglove_cpp_shared${CMAKE_SHARED_LIBRARY_SUFFIX}"
  INTERFACE_INCLUDE_DIRECTORIES "${_fbc_prefix}/include"
)
if(FOXGLOVE_BRIDGE_CORE_REMOTE_ACCESS)
  set_property(TARGET foxglove_bridge_core::foxglove_cpp APPEND PROPERTY
    INTERFACE_COMPILE_DEFINITIONS FOXGLOVE_REMOTE_ACCESS)
endif()

add_library(foxglove_bridge_core::foxglove_bridge_core SHARED IMPORTED)
set_target_properties(foxglove_bridge_core::foxglove_bridge_core PROPERTIES
  IMPORTED_LOCATION "${_fbc_prefix}/lib/${CMAKE_SHARED_LIBRARY_PREFIX}foxglove_bridge_core${CMAKE_SHARED_LIBRARY_SUFFIX}"
  INTERFACE_INCLUDE_DIRECTORIES "${_fbc_prefix}/include"
  INTERFACE_LINK_LIBRARIES foxglove_bridge_core::foxglove_cpp
)

unset(_fbc_prefix)

# foxglove_msgs/SelectedEntity
# Information about a selected entity in a visualization panel

# Generated by https://github.com/foxglove/foxglove-sdk

# Topic from which the entity originated
string source_topic

# Schema name of the source message
string source_schema_name

# Selected scene entity
foxglove_msgs/SceneEntity scene_entity

# Selected point cloud
foxglove_msgs/PointCloud point_cloud

# Selected laser scan
foxglove_msgs/LaserScan laser_scan

# Selected grid
foxglove_msgs/Grid grid

# Selected voxel grid
foxglove_msgs/VoxelGrid voxel_grid

# Selected camera calibration
foxglove_msgs/CameraCalibration camera_calibration

# Selected pose in frame
foxglove_msgs/PoseInFrame pose_in_frame

# Selected poses in frame
foxglove_msgs/PosesInFrame poses_in_frame
